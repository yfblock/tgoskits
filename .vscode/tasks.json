{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TGOS: Start ArceOS QEMU debug",
      "hide": true,
      "isBackground": true,
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}/.vscode/session.py",
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "TGOS_DEBUG_COMMAND": "cargo xtask arceos qemu --debug --package ax-helloworld --arch aarch64",
          "TGOS_DEBUG_PORT": "1234",
          "TGOS_DEBUG_SESSION": "arceos",
          "TGOS_DEBUG_STATE_DIR": "${workspaceFolder}/target/qemu-debug"
        }
      },
      "presentation": {
        "close": true,
        "echo": false,
        "focus": false,
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": {
        "owner": "arceos-qemu",
        "pattern": {
          "regexp": "^(QEMU_DEBUG_FAILED).*$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^QEMU_DEBUG_STARTING session=arceos\\b.*$",
          "endsPattern": "^QEMU_GDB_READY session=arceos\\b.*$"
        }
      }
    },
    {
      "label": "TGOS: Stop ArceOS QEMU debug",
      "hide": true,
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}/.vscode/session.py",
        "stop"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "TGOS_DEBUG_SESSION": "arceos",
          "TGOS_DEBUG_STATE_DIR": "${workspaceFolder}/target/qemu-debug"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "close": true,
        "echo": false,
        "panel": "shared",
        "reveal": "never"
      }
    },
